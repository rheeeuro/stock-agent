{
  "permissions": {
    "allow": [
      "Bash(uv run :*)",
      "Bash(cd jongalab/frontend && npx tsc --noEmit)",
      "Bash(cd jongalab/frontend && npm run lint)",
      "Bash(cd jongalab/frontend && npm run dev)",
      "Bash(npx tsc --noEmit)",
      "Bash(npm run lint)",
      "Bash(pm2 logs :*)",
      "Bash(pm2 status)",
      "Bash(pm2 jlist)",
      "Bash(pm2 restart :*)",
      "Bash(cd jongalab/frontend && npm run build)",
      "Bash(docker exec :*)",
      "Bash(docker ps :*)",
      "Bash(curl -s http://127.0.0.1:* :*)",
      "Bash(curl -s -o /dev/null -w :*)",
      "Bash(grep :*)",
      "Bash(rg :*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./**/*.session)",
      "Read(./**/*.session-journal)",
      "Read(./mariadb_data/**)",
      "Read(./ollama_data/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/guard-sensitive.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/quality-gate.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/track-changes.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/deploy-on-stop.sh"
          }
        ]
      }
    ]
  }
}
